Options -Indexes
DirectoryIndex index.php

<IfModule mod_headers.c>
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "same-origin"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Blok akses langsung ke folder internal dan dotfile, kecuali .well-known untuk SSL.
  RewriteRule ^(?:\.git|\.agents|\.codex)(?:/|$) - [F,L]
  RewriteRule (^|/)\.(?!well-known(?:/|$)) - [F,L]

  # Kompatibilitas event lama: SDK lama diarahkan ke SDK tunggal resmi.
  RewriteRule ^assets/rahasiaemas-sdk\.js$ assets/event-sdk.js [L,NC]

  # Hanya izinkan route publik/admin yang memang aktif.
  RewriteRule !^(?:$|index\.php|buat-link\.php|assets/[A-Za-z0-9._/-]+\.(?:png|jpe?g|webp|gif|svg|ico|css|js|woff2?|ttf|eot)|uploads/brands/[A-Za-z0-9_-]+/[A-Za-z0-9._-]+\.(?:png|jpe?g|webp|gif|svg)|api/(?:submit_lead|create_referrer|event_info)\.php|challenge/?|challenge/index\.php|e/[A-Za-z0-9._/-]+|admin/?|admin/(?:index|login|dashboard|logout|export|events|event-settings|rewards|tracking|setup-brand|documentation|generate-password-hash|migrate-legacy)\.php)$ - [F,L,NC]
</IfModule>

# Blok file konfigurasi, database, dokumentasi, backup, log, dan metadata project.
<FilesMatch "^(?:config\.php|install\.sql|README\.md|index-old\.html|composer\.(?:json|lock)|package(?:-lock)?\.json|\.env.*)$">
  Require all denied
</FilesMatch>

<FilesMatch "\.(?:sql|bak|backup|old|orig|save|swp|ini|log|md|yml|yaml|json|lock|sh|ps1|bat|cmd)$">
  Require all denied
</FilesMatch>
