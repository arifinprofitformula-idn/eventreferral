# ============================================================
# Pengaman folder /e/ — tempat landing page hasil upload ZIP disimpan.
# File di folder ini seharusnya HANYA html/css/js/gambar/font.
# Baris di bawah memastikan walau ada file .php yang lolos masuk
# (seharusnya tidak mungkin karena sistem sudah memfilter saat upload),
# file tersebut tidak akan pernah dieksekusi oleh server.
# ============================================================

<IfModule mod_php7.c>
    php_flag engine off
</IfModule>
<IfModule mod_php8.c>
    php_flag engine off
</IfModule>

<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|phar|pl|py|cgi|sh|exe)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

Options -Indexes
DirectoryIndex index.html
